{
  "manifest_version": 3,
  "name": "PolyKybd Website Reporter",
  "version": "1.0.0",
  "description": "Reports the active browser tab's URL to PolyKybdHost so it can show website-specific keycap overlays.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": { "scripts": ["background.js"] },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "browser_specific_settings": {
    "gecko": {
      "id": "website-reporter@polykybd",
      "strict_min_version": "115.0"
    }
  }
}
